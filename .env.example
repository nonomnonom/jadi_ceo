# Juragan — root .env.example
# Copy to .env at the repo root, fill in the required values, then `pnpm dev`.
# You can also save OPENROUTER_API_KEY and TELEGRAM_BOT_TOKEN via the dashboard
# Settings tab after first boot — they'll be promoted into env on next restart.

# ─── LLM provider (required) ─────────────────────────────────────────────
# OpenRouter key. Get one at https://openrouter.ai/keys. Format: sk-or-v1-...
OPENROUTER_API_KEY=

# ─── Telegram (required for the owner-facing bot) ────────────────────────
# Bot token from @BotFather. Format: 7000000000:AAH...
TELEGRAM_BOT_TOKEN=

# Owner's Telegram chat id — target for reminder push notifications.
# Get it by DM-ing @userinfobot on Telegram. Numeric, e.g. 123456789.
# Hot-reloadable: this one doesn't require an API restart.
TELEGRAM_OWNER_CHAT_ID=

# Optional Telegram tuning — only set if you know what they do:
# TELEGRAM_WEBHOOK_SECRET_TOKEN=   # only for webhook mode (prod)
# TELEGRAM_BOT_USERNAME=           # skips one getMe round-trip at startup
# TELEGRAM_API_BASE_URL=           # self-hosted Bot API gateway

# ─── Storage ─────────────────────────────────────────────────────────────
# LibSQL URL. Default keeps a file under apps/api/data/. Swap to libsql://...
# for Turso or any remote libsql.
DATABASE_URL=file:./data/juragan.db

# ─── Queue (Redis / BullMQ) ──────────────────────────────────────────────
# Used by apps/worker for exact-time reminder dispatch. If Redis is down, the
# API falls back to an in-process setInterval that still fires (slower).
REDIS_URL=redis://localhost:6379

# ─── Tenant ──────────────────────────────────────────────────────────────
# Single-tenant for now. Leave as-is unless you know what you're doing.
DEFAULT_TENANT_ID=default

# ─── Dashboard auth (required for production) ────────────────────────────
# Protects /custom/* API routes + dashboard. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In production, set via environment — never commit a real secret to git.
DASHBOARD_SECRET=

# ─── API server ──────────────────────────────────────────────────────────
PORT=4111

# ─── Auth & encryption (Phase 3 — not yet wired) ─────────────────────────
# DASHBOARD_SECRET is wired now (protects /custom/* routes + dashboard).
# When the full auth layer lands these will add user accounts + role-based access.
# ADMIN_USERNAME=owner
# ADMIN_PASSWORD=change-me
# ENCRYPTION_KEY=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
# SESSION_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
