# LLM provider — BYO key via OpenRouter (model: openrouter/anthropic/claude-sonnet-4.6)
# Can also be saved via the dashboard Settings tab; DB-stored value is promoted
# into process.env at startup if this is empty.
OPENROUTER_API_KEY=

# Telegram — minimum needed is the bot token (from @BotFather). Can also be saved
# via the dashboard Settings tab.
TELEGRAM_BOT_TOKEN=

# Optional Telegram env vars (only needed in specific situations):
# - TELEGRAM_WEBHOOK_SECRET_TOKEN: set this AND register the webhook URL with
#   Telegram's setWebhook using the same secret. Used to verify that incoming
#   webhook requests really come from Telegram. Only relevant for webhook mode
#   (production deploys). Irrelevant for polling mode (local dev).
# - TELEGRAM_BOT_USERNAME: lets the adapter skip a getMe round-trip at startup
#   for mention detection. If omitted the adapter calls getMe once itself.
# - TELEGRAM_API_BASE_URL: override if you run a self-hosted Bot API gateway.
#   Defaults to https://api.telegram.org.
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_BOT_USERNAME=
# TELEGRAM_API_BASE_URL=https://api.telegram.org

# Storage — LibSQL local file. Change to a libsql:// URL for Turso.
DATABASE_URL=file:./data/juragan.db

# Single-tenant default. Multi-tenant via request context arrives in M3.
DEFAULT_TENANT_ID=default

# Mastra dev server
PORT=4111
