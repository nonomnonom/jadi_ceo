# LLM provider — BYO key via OpenRouter (model: openrouter/anthropic/claude-sonnet-4.6)
OPENROUTER_API_KEY=

# Telegram channel (wired in M4)
TELEGRAM_BOT_TOKEN=

# Storage — LibSQL local file. Change to a libsql:// URL for Turso.
DATABASE_URL=file:./data/juragan.db

# Single-tenant default. Multi-tenant via request context arrives in M3.
DEFAULT_TENANT_ID=default

# Mastra dev server
PORT=4111
