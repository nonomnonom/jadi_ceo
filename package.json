{
  "name": "juragan",
  "private": true,
  "scripts": {
    "setup": "pnpm install && node -e \"require('fs').existsSync('.env')||require('fs').copyFileSync('.env.example','.env')\" && docker compose up -d redis",
    "start": "turbo run dev",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "check": "pnpm check-types && pnpm lint",
    "check-types": "turbo run check-types",
    "format": "biome format --write .",
    "format:check": "biome format --check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
