# ============================================================
# Juragan — Environment Variables untuk Production
# ============================================================
# Salin file ini ke .env di folder yang sama, lalu isi nilainya.
# Semua variabel WAJIB diisi kecuali yang ditandaiOpsional.
#
# Cara generate DASHBOARD_SECRET:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ============================================================

# ─── AI Provider (WAJIB) ────────────────────────────────────
# Kunci API OpenRouter. Daftar di https://openrouter.ai/keys
# Format: sk-or-v1-...
OPENROUTER_API_KEY=

# ─── Telegram (WAJIB untuk bot owner) ────────────────────────
# Token bot dari @BotFather. Format: 7000000000:AAH...
TELEGRAM_BOT_TOKEN=

# Chat ID owner Telegram — untuk menerima push pengingat.
# Cara dapat: DM @userinfobot di Telegram, lihat field "Id".
TELEGRAM_OWNER_CHAT_ID=

# ─── Penyimpanan Data ───────────────────────────────────────
# URL LibSQL. Default: file SQLite di ./data/juragan.db
# Untuk production: gunakan Turso (libsql://...) atau database remote.
DATABASE_URL=file:./data/juragan.db

# ─── Queue (Redis / BullMQ) ──────────────────────────────────
# Digunakan worker untuk dispatch pengingat yang terjadwal.
REDIS_URL=redis://redis:6379

# ─── Tenant ──────────────────────────────────────────────────
# Untuk single-tenant. Biarkan default kecuali tahu apa yang dilakukan.
DEFAULT_TENANT_ID=default

# ─── Dashboard Auth (WAJIB) ──────────────────────────────────
# Rahasia untuk melindungi /custom/* API routes dan dashboard.
# HARUS di-set untuk production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SECRET=

# ─── Server ──────────────────────────────────────────────────
PORT=4111

# ─── Opsi Tambahan ────────────────────────────────────────────
# TELEGRAM_WEBHOOK_SECRET_TOKEN=   # hanya untuk mode webhook (prod)
# TELEGRAM_API_BASE_URL=           # self-hosted Bot API gateway
# SMTP_HOST=                       # host SMTP untuk email notifikasi (Opsional)
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
