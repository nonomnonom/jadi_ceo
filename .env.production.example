# Juragan production environment
# Copy to .env.production (never commit real values), then:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up

# ─── LLM provider ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Telegram ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# ─── Storage ─────────────────────────────────────────────────────────────
DATABASE_URL=file:./data/juragan.db

# ─── Queue ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Tenant ──────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=default

# ─── Dashboard auth (REQUIRED in production) ────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SECRET=
