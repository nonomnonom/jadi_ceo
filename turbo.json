{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".mastra/**", "dist/**", "!.mastra/cache/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["src/**", "tests/**", "biome.json", "../../biome.json"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "inputs": ["src/**", "tests/**", "tsconfig.json", "../../tsconfig.base.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
